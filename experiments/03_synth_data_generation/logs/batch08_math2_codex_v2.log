--- /dev/null
+++ b/experiments/03_synth_data_generation/output/temp_batch08_validation_collatz.lean
@@ -0,0 +1,24 @@
+partial def collatz_steps (n : Nat) : Nat :=
+  if n = 0 ∨ n = 1 then
+    0
+  else if n % 2 = 0 then
+    1 + collatz_steps (n / 2)
+  else
+    1 + collatz_steps (3 * n + 1)
+
+def triangular_number (n : Nat) : Nat :=
+  n * (n + 1) / 2
+
+def is_even (n : Int) : Bool :=
+  n % 2 == 0
+
+def is_odd (n : Int) : Bool :=
+  n % 2 != 0
+
