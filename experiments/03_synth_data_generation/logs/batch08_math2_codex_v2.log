    sources = {
        "gcd": "def gcd(a: int, b: int) -> int:\n    while b != 0:\n        a, b = b, a % b\n    return a",
        "lcm": "def lcm(a: int, b: int) -> int:\n    if a == 0 or b == 0:\n        return 0\n    return (a // gcd(a, b)) * b",
        "power": "def power(base: int, exp: int) -> int:\n    result = 1\n    while exp > 0:\n        if exp % 2 == 1:\n            result *= base\n        base *= base\n        exp //= 2\n    return result",
        "is_prime": "def is_prime(n: int) -> bool:\n    if n < 2:\n        return False\n    if n == 2:\n        return True\n    if n % 2 == 0:\n        return False\n    i = 3\n    while i * i <= n:\n        if n % i == 0:\n            return False\n        i += 2\n    return True",
        "mod_exp": "def mod_exp(base: int, exp: int, mod: int) -> int:\n    if mod == 0:\n        return 0\n    result = 1\n    base = base % mod\n    while exp > 0:\n        if exp % 2 == 1:\n            result = (result * base) % mod\n        exp //= 2\n        base = (base * base) % mod\n    return result",
        "sum_digits": "def sum_digits(n: int) -> int:\n    s = 0\n    while n > 0:\n        s += n % 10\n        n //= 10\n    return s",
        "count_digits": "def count_digits(n: int) -> int:\n    if n == 0:\n        return 1\n    c = 0\n    while n > 0:\n        c += 1\n        n //= 10\n    return c"
    }
    return sources[name]

def get_lean_translation(name, lang):
    if lang == "C":
        translations = {
            "gcd": "partial def gcd (a b : UInt32) : UInt32 :=\n  if b == 0 then a else gcd b (a % b)",
            "lcm": "partial def gcd (a b : UInt32) : UInt32 :=\n  if b == 0 then a else gcd b (a % b)\n\ndef lcm (a b : UInt32) : UInt32 :=\n  if a == 0 || b == 0 then 0 else (a / gcd a b) * b",
            "power": "partial def power (base exp : UInt32) : UInt32 :=\n  let rec loop (b e res : UInt32) : UInt32 :=\n    if e == 0 then res\n    else\n      let next_res := if e % 2 == 1 then res * b else res\n      loop (b * b) (e / 2) next_res\n  loop base exp 1",
            "is_prime": "partial def is_prime (n : UInt32) : Bool :=\n  if n < 2 then false\n  else if n == 2 then true\n  else if n % 2 == 0 then false\n  else\n    let rec loop (i : UInt32) : Bool :=\n      if i * i > n then true\n      else if n % i == 0 then false\n      else loop (i + 2)\n    loop 3",
            "mod_exp": "partial def mod_exp (base exp mod : UInt32) : UInt32 :=\n  if mod == 0 then 0\n  else\n    let rec loop (b e res : UInt32) : UInt32 :=\n      if e == 0 then res\n      else\n        let next_res := if e % 2 == 1 then (res * b) % mod else res\n        loop (b * b % mod) (e / 2) next_res\n    loop (base % mod) exp 1",
            "sum_digits": "partial def sum_digits (n : UInt32) : UInt32 :=\n  if n == 0 then 0\n  else n % 10 + sum_digits (n / 10)",
            "count_digits": "partial def count_digits (n : UInt32) : UInt32 :=\n  if n == 0 then 1\n  else\n    let rec loop (val count : UInt32) : UInt32 :=\n      if val == 0 then count\n      else loop (val / 10) (count + 1)\n    loop n 0"
        }
    else: # Python -> Nat
        translations = {
            "gcd": "partial def gcd (a b : Nat) : Nat :=\n  if b = 0 then a else gcd b (a % b)",
            "lcm": "partial def gcd (a b : Nat) : Nat :=\n  if b = 0 then a else gcd b (a % b)\n\npartial def lcm (a b : Nat) : Nat :=\n  if a = 0 || b = 0 then 0 else (a / gcd a b) * b",
            "power": "partial def power (base exp : Nat) : Nat :=\n  let rec loop (b e res : Nat) : Nat :=\n    if e = 0 then res\n    else\n      let next_res := if e % 2 = 1 then res * b else res\n      loop (b * b) (e / 2) next_res\n  loop base exp 1",
            "is_prime": "partial def is_prime (n : Nat) : Bool :=\n  if n < 2 then false\n  else if n = 2 then true\n  else if n % 2 = 0 then false\n  else\n    let rec loop (i : Nat) : Bool :=\n      if i * i > n then true\n      else if n % i = 0 then false\n      else loop (i + 2)\n    loop 3",
            "mod_exp": "partial def mod_exp (base exp mod : Nat) : Nat :=\n  if mod = 0 then 0\n  else\n    let rec loop (b e res : Nat) : Nat :=\n      if e = 0 then res\n      else\n        let next_res := if e % 2 = 1 then (res * b) % mod else res\n        loop (b * b % mod) (e / 2) next_res\n    loop (base % mod) exp 1",
            "sum_digits": "partial def sum_digits (n : Nat) : Nat :=\n  if n = 0 then 0\n  else n % 10 + sum_digits (n / 10)",
            "count_digits": "partial def count_digits (n : Nat) : Nat :=\n  if n = 0 then 1\n  else\n    let rec loop (val count : Nat) : Nat :=\n      if val = 0 then count\n      else loop (val / 10) (count + 1)\n    loop n 0"
        }
    return translations[name]

def get_c_tests(name):
    source = get_c_source(name)
    main = ""
    if name == "gcd":
        main = "int main() { assert(gcd(48, 18) == 6); assert(gcd(101, 103) == 1); assert(gcd(0, 5) == 5); return 0; }"
    elif name == "lcm":
        main = "int main() { assert(lcm(12, 18) == 36); assert(lcm(0, 5) == 0); return 0; }"
    elif name == "power":
        main = "int main() { assert(power(2, 10) == 1024); assert(power(3, 4) == 81); assert(power(5, 0) == 1); return 0; }"
    elif name == "is_prime":
        main = "int main() { assert(is_prime(2) == 1); assert(is_prime(7) == 1); assert(is_prime(10) == 0); assert(is_prime(1) == 0); return 0; }"
    elif name == "mod_exp":
        main = "int main() { assert(mod_exp(2, 10, 1000) == 24); assert(mod_exp(5, 3, 13) == 8); return 0; }"
    elif name == "sum_digits":
        main = "int main() { assert(sum_digits(123) == 6); assert(sum_digits(0) == 0); return 0; }"
    elif name == "count_digits":
        main = "int main() { assert(count_digits(123) == 3); assert(count_digits(0) == 1); return 0; }"
    return f"#include <assert.h>\n{source}\n{main}"

def get_py_tests(name):
    source = get_py_source(name)
    tests = ""
    if name == "gcd":
        tests = "assert gcd(48, 18) == 6\nassert gcd(101, 103) == 1\nassert gcd(0, 5) == 5"
    elif name == "lcm":
        tests = "assert lcm(12, 18) == 36\nassert lcm(0, 5) == 0"
    elif name == "power":
        tests = "assert power(2, 10) == 1024\nassert power(3, 4) == 81\nassert power(5, 0) == 1"
    elif name == "is_prime":
        tests = "assert is_prime(2) == True\nassert is_prime(7) == True\nassert is_prime(10) == False\nassert is_prime(1) == False"
    elif name == "mod_exp":
        tests = "assert mod_exp(2, 10, 1000) == 24\nassert mod_exp(5, 3, 13) == 8"
    elif name == "sum_digits":
        tests = "assert sum_digits(123) == 6\nassert sum_digits(0) == 0"
    elif name == "count_digits":
        tests = "assert count_digits(123) == 3\nassert count_digits(0) == 1"
    return f"{source}\n{tests}"

