def get_theorems(name):
    if name == "gcd":
        return [{"name": "gcd_comm", "statement": "theorem gcd_comm (a b : Nat) : gcd a b = gcd b a", "proof": "by sorry"}]
    elif name == "lcm":
        return [{"name": "lcm_comm", "statement": "theorem lcm_comm (a b : Nat) : lcm a b = lcm b a", "proof": "by sorry"}]
    elif name == "power":
        return [{"name": "power_zero", "statement": "theorem power_zero (b : Nat) : power b 0 = 1", "proof": "by rfl"}]
    elif name == "is_prime":
        return [{"name": "is_prime_seven", "statement": "theorem is_prime_seven : is_prime 7 = true", "proof": "by native_decide"}]
    elif name == "mod_exp":
        return [{"name": "mod_exp_one", "statement": "theorem mod_exp_one (b m : Nat) : m > 0 → mod_exp b 0 m = 1", "proof": "by sorry"}]
    elif name == "sum_digits":
        return [{"name": "sum_digits_le", "statement": "theorem sum_digits_le (n : Nat) : sum_digits n <= n", "proof": "by sorry"}]
    elif name == "count_digits":
        return [{"name": "count_digits_pos", "statement": "theorem count_digits_pos (n : Nat) : count_digits n >= 1", "proof": "by sorry"}]
    return []

