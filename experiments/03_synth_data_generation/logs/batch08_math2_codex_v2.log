+    x = n
+    y = (x + 1) // 2
+    while y < x:
+        x = y
+        y = (x + n // x) // 2
+    return x""",
+        "is_perfect_square": """def is_perfect_square(n: int) -> bool:
+    s = integer_sqrt(n)
+    return s * s == n""",
+        "binomial": """def binomial(n: int, k: int) -> int:
+    if k > n:
+        return 0
+    if k == 0 or k == n:
+        return 1
+    if k > n - k:
+        k = n - k
+    result = 1
+    for i in range(k):
+        result = result * (n - i) // (i + 1)
+    return result""",
