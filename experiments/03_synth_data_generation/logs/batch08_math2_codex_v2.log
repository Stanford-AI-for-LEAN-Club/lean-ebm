+    steps = 0
+    while n != 1 and n != 0:
+        if n % 2 == 0:
+            n = n // 2
+        else:
+            n = 3 * n + 1
+        steps += 1
+    return steps""",
+        "digital_root": """def digital_root(n: int) -> int:
+    if n == 0:
