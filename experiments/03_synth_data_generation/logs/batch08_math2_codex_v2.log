+        loop (x + 1)
+      else
+        x
+    loop 0
+
+partial def binomial (n k : Nat) : Nat :=
+  if k > n then
+    0
+  else if k = 0 || k = n then
+    1
+  else
+    let k' := if k > n - k then n - k else k
+    let rec loop (i result : Nat) : Nat :=
+      if i < k' then
+        loop (i + 1) (result * (n - i) / (i + 1))
+      else
+        result
+    loop 0 1
+
+def digital_root (n : Nat) : Nat :=
+  if n = 0 then
+    0
+  else
+    1 + (n - 1) % 9
