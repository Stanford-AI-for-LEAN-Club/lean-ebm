+                let n := n - 1
+                let n := n ||| (n >>> 1)
+                let n := n ||| (n >>> 2)
+                let n := n ||| (n >>> 4)
+                let n := n ||| (n >>> 8)
+                let n := n ||| (n >>> 16)
+                n + 1
+            """
+        ),
