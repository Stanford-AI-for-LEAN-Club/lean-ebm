+            """
+        ),
+        "clear_lowest_set_bit": block(
+            """
+            def clear_lowest_set_bit (n : Nat) : Nat :=
+              n - lowest_set_bit n
+            """
+        ),
+    }
+
+    translations = c_translations if language == "C" else py_translations
     return translations[name]
 
