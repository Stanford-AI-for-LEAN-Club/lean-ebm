+            """
+            def is_power_of_two_go (m : Nat) : Nat -> Bool
+              | 0 => false
+              | fuel + 1 =>
+                  if m == 1 then true
+                  else if m == 0 then false
+                  else if m % 2 == 1 then false
+                  else is_power_of_two_go (m / 2) fuel
