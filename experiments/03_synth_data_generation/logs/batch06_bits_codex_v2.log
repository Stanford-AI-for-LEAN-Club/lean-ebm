+                  else candidate
+
+            def next_power_of_two (n : Nat) : Nat :=
+              if n == 0 then 1 else next_power_of_two_go n 1 (n + 1)
+            """
+        ),
+        "lowest_set_bit": block(
+            """
+            def lowest_set_bit_go (m bit : Nat) : Nat -> Nat
