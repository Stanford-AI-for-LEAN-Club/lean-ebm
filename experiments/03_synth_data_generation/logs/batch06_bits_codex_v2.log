import json
import os

def get_c_source(name):
    sources = {
        "linear_search": """int linear_search(const int *arr, int n, int target) {
    for (int i = 0; i < n; i++) {
        if (arr[i] == target) return i;
    }
    return -1;
}""",
        "binary_search": """int binary_search(const int *arr, int n, int target) {
    int lo = 0, hi = n - 1;
    while (lo <= hi) {
        int mid = lo + (hi - lo) / 2;
        if (arr[mid] == target) return mid;
        if (arr[mid] < target) lo = mid + 1;
        else hi = mid - 1;
    }
    return -1;
}""",
        "find_first": """int find_first(const int *arr, int n, int target) {
    int lo = 0, hi = n - 1, result = -1;
    while (lo <= hi) {
        int mid = lo + (hi - lo) / 2;
        if (arr[mid] == target) {
            result = mid;
            hi = mid - 1;
        } else if (arr[mid] < target) {
            lo = mid + 1;
        } else {
            hi = mid - 1;
        }
    }
    return result;
}""",
        "find_last": """int find_last(const int *arr, int n, int target) {
    int lo = 0, hi = n - 1, result = -1;
    while (lo <= hi) {
        int mid = lo + (hi - lo) / 2;
        if (arr[mid] == target) {
            result = mid;
            lo = mid + 1;
        } else if (arr[mid] < target) {
            lo = mid + 1;
        } else {
            hi = mid - 1;
        }
    }
    return result;
}""",
        "contains": """int contains(const int *arr, int n, int val) {
    for (int i = 0; i < n; i++) {
        if (arr[i] == val) return 1;
    }
    return 0;
}""",
        "index_of_max": """int index_of_max(const int *arr, int n) {
    int idx = 0;
    for (int i = 1; i < n; i++) {
        if (arr[i] > arr[idx]) idx = i;
    }
    return idx;
}"""
    }
    return sources[name]

def get_py_source(name):
    sources = {
        "linear_search": """def linear_search(arr: list[int], target: int) -> int:
    for i in range(len(arr)):
        if arr[i] == target:
            return i
    return -1""",
        "binary_search": """def binary_search(arr: list[int], target: int) -> int:
    lo, hi = 0, len(arr) - 1
    while lo <= hi:
        mid = lo + (hi - lo) // 2
        if arr[mid] == target:
            return mid
        if arr[mid] < target:
            lo = mid + 1
        else:
            hi = mid - 1
    return -1""",
        "find_first": """def find_first(arr: list[int], target: int) -> int:
    lo, hi, result = 0, len(arr) - 1, -1
    while lo <= hi:
        mid = lo + (hi - lo) // 2
        if arr[mid] == target:
            result = mid
            hi = mid - 1
        elif arr[mid] < target:
            lo = mid + 1
        else:
            hi = mid - 1
    return result""",
        "find_last": """def find_last(arr: list[int], target: int) -> int:
    lo, hi, result = 0, len(arr) - 1, -1
    while lo <= hi:
        mid = lo + (hi - lo) // 2
        if arr[mid] == target:
            result = mid
            lo = mid + 1
        elif arr[mid] < target:
            lo = mid + 1
        else:
            hi = mid - 1
    return result""",
        "contains": """def contains(arr: list[int], val: int) -> bool:
    for x in arr:
        if x == val:
            return True
    return False""",
        "index_of_max": """def index_of_max(arr: list[int]) -> int:
    idx = 0
    for i in range(1, len(arr)):
        if arr[i] > arr[idx]:
            idx = i
    return idx"""
    }
    return sources[name]

def get_lean_translation(name, lang):
    # Use Int for C/Python ints, but indices often better as Nat in Lean if we know they are >= 0.
    # For binary search, lo/hi can be Int because of hi = n - 1 (which can be -1).
    
    translations = {
        "linear_search": """partial def linear_search (arr : List Int) (target : Int) : Int :=
  let rec loop (i : Nat) : Int :=
    match arr.get? i with
    | some x => if x == target then i else loop (i + 1)
    | none => -1
  loop 0""",
        "binary_search": """partial def binary_search (arr : List Int) (target : Int) : Int :=
  let rec loop (lo hi : Int) : Int :=
    if lo > hi then -1
    else
      let mid := lo + (hi - lo) / 2
      match arr.get? mid.toNat with
      | some x =>
        if x == target then mid
        else if x < target then loop (mid + 1) hi
        else loop lo (mid - 1)
      | none => -1
  loop 0 (arr.length - 1)""",
        "find_first": """partial def find_first (arr : List Int) (target : Int) : Int :=
  let rec loop (lo hi result : Int) : Int :=
    if lo > hi then result
    else
      let mid := lo + (hi - lo) / 2
      match arr.get? mid.toNat with
      | some x =>
        if x == target then loop lo (mid - 1) mid
        else if x < target then loop (mid + 1) hi result
        else loop lo (mid - 1) result
      | none => result
  loop 0 (arr.length - 1) (-1)""",
        "find_last": """partial def find_last (arr : List Int) (target : Int) : Int :=
  let rec loop (lo hi result : Int) : Int :=
    if lo > hi then result
    else
      let mid := lo + (hi - lo) / 2
      match arr.get? mid.toNat with
      | some x =>
        if x == target then loop (mid + 1) hi mid
        else if x < target then loop (mid + 1) hi result
        else loop lo (mid - 1) result
      | none => result
  loop 0 (arr.length - 1) (-1)""",
        "contains": """def contains (arr : List Int) (val : Int) : Bool :=
  match arr with
  | [] => false
  | x :: xs => if x == val then true else contains xs val""" if lang == "Python" else
        """def contains (arr : List Int) (val : Int) : Int :=
  match arr with
  | [] => 0
  | x :: xs => if x == val then 1 else contains xs val""",
        "index_of_max": """partial def index_of_max (arr : List Int) : Int :=
  if arr.isEmpty then 0
  else
    let rec loop (i : Nat) (maxIdx : Nat) : Nat :=
      match arr.get? i with
      | some x =>
        if x > arr.get! maxIdx then loop (i + 1) i
        else loop (i + 1) maxIdx
      | none => maxIdx
    loop 1 0"""
    }
