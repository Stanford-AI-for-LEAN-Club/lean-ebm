def is_palindrome (s : String) : Bool :=
  let s_list := s.toList
  s_list == s_list.reverse

#eval is_palindrome "racecar"
#eval is_palindrome "hello"

def is_palindrome_c (s : String) (len : Int) : Bool :=
  let rec loop (i : Int) : Bool :=
    if i < len / 2 then
      let char_i := s.get (s.atIdx i.toNat)
      let char_last_i := s.get (s.atIdx (len.toNat - 1 - i.toNat))
      if char_i != char_last_i then false
      else loop (i + 1)
    else true
  loop 0
  termination_by (len / 2 - i).toNat

