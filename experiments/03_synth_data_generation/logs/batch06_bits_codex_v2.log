+                  if n == 0 then acc
+                  else count_set_bits_go (n >>> 1) (acc + (n &&& 1)) fuel
+
+            def count_set_bits (n : UInt32) : UInt32 :=
+              count_set_bits_go n 0 32
+            """
+        ),
+        "parity": block(
+            """
+            def parity_go (n acc : UInt32) : Nat -> UInt32
+              | 0 => acc
+              | fuel + 1 =>
+                  if n == 0 then acc
+                  else parity_go (n >>> 1) (acc ^^^ (n &&& 1)) fuel
+
+            def parity (n : UInt32) : UInt32 :=
+              parity_go n 0 32
+            """
+        ),
