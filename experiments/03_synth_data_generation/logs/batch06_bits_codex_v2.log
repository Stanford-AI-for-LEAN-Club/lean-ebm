    return {
        "language": language,
        "source": get_c_source(name) if language == "C" else get_py_source(name),
        "lean_translation": get_lean_translation(name),
        "tests": get_c_tests(name) if language == "C" else get_py_tests(name),
        "lean_tests": get_lean_tests(name),
        "theorems": get_theorems(name),
        "deps_fully_translated": [],
        "axiomatized_deps": [],
        "skip_reason": None,
    }


def main() -> None:
    OUTPUT_PATH.parent.mkdir(parents=True, exist_ok=True)
    with OUTPUT_PATH.open("w", encoding="utf-8") as f:
        for language in ("C", "Python"):
            for name in FUNCTIONS:
                f.write(json.dumps(build_record(language, name)) + "\n")


if __name__ == "__main__":
    main()

