def get_py_source(name: str) -> str:
    sources = {
        "sum_array": block(
            """
            def sum_array(arr: list[int]) -> int:
                s = 0
                for x in arr:
                    s += x
                return s
            """
        ),
        "product_array": block(
            """
            def product_array(arr: list[int]) -> int:
                p = 1
                for x in arr:
                    p *= x
                return p
            """
        ),
        "max_element": block(
            """
            def max_element(arr: list[int]) -> int:
                m = arr[0]
                for i in range(1, len(arr)):
                    if arr[i] > m:
                        m = arr[i]
                return m
            """
        ),
        "min_element": block(
            """
            def min_element(arr: list[int]) -> int:
                m = arr[0]
                for i in range(1, len(arr)):
                    if arr[i] < m:
                        m = arr[i]
                return m
            """
        ),
        "reverse_array": block(
            """
            def reverse_array(arr: list[int]) -> list[int]:
                result = arr[:]
                n = len(result)
                for i in range(n // 2):
                    result[i], result[n - 1 - i] = result[n - 1 - i], result[i]
                return result
            """
        ),
        "is_sorted": block(
            """
            def is_sorted(arr: list[int]) -> bool:
                for i in range(len(arr) - 1):
                    if arr[i] > arr[i + 1]:
                        return False
                return True
            """
        ),
        "count_occurrences": block(
            """
            def count_occurrences(arr: list[int], val: int) -> int:
                c = 0
                for x in arr:
                    if x == val:
                        c += 1
                return c
            """
        ),
    }
    return sources[name]


def get_lean_translation(name: str) -> str:
    translations = {
        "sum_array": block(
            """
            def sum_array (arr : Array Int) : Int :=
              arr.foldl (fun acc x => acc + x) 0
            """
        ),
        "product_array": block(
            """
            def product_array (arr : Array Int) : Int :=
              arr.foldl (fun acc x => acc * x) 1
            """
        ),
        "max_element": block(
            """
            def max_element (arr : Array Int) : Int :=
              match arr[0]? with
              | none => 0
              | some first => arr.foldl (fun m x => if x > m then x else m) first
            """
        ),
        "min_element": block(
            """
            def min_element (arr : Array Int) : Int :=
              match arr[0]? with
              | none => 0
              | some first => arr.foldl (fun m x => if x < m then x else m) first
            """
        ),
        "reverse_array": block(
            """
            def reverse_array (arr : Array Int) : Array Int :=
              arr.reverse
            """
        ),
        "is_sorted": block(
            """
            def is_sorted (arr : Array Int) : Bool :=
              (List.zip arr.toList (arr.toList.drop 1)).all (fun p => decide (p.1 <= p.2))
            """
        ),
        "count_occurrences": block(
            """
            def count_occurrences (arr : Array Int) (val : Int) : Int :=
              arr.foldl (fun c x => if x == val then c + 1 else c) 0
            """
        ),
    }
    return translations[name]


