import json
import os

def get_c_source(name):
    sources = {
        "is_power_of_two": "int is_power_of_two(unsigned int n) {\n    return n != 0 && (n & (n - 1)) == 0;\n}",
        "count_set_bits": "unsigned int count_set_bits(unsigned int n) {\n    unsigned int count = 0;\n    while (n) {\n        count += n & 1;\n        n >>= 1;\n    }\n    return count;\n}",
        "parity": "unsigned int parity(unsigned int n) {\n    unsigned int p = 0;\n    while (n) {\n        p ^= (n & 1);\n        n >>= 1;\n    }\n    return p;\n}",
        "reverse_bits": "unsigned int reverse_bits(unsigned int n) {\n    unsigned int result = 0;\n    for (int i = 0; i < 32; i++) {\n        result = (result << 1) | (n & 1);\n        n >>= 1;\n    }\n    return result;\n}",
        "next_power_of_two": "unsigned int next_power_of_two(unsigned int n) {\n    if (n == 0) return 1;\n    n--;\n    n |= n >> 1;\n    n |= n >> 2;\n    n |= n >> 4;\n    n |= n >> 8;\n    n |= n >> 16;\n    return n + 1;\n}",
        "lowest_set_bit": "unsigned int lowest_set_bit(unsigned int n) {\n    return n & (~n + 1);\n}",
        "clear_lowest_set_bit": "unsigned int clear_lowest_set_bit(unsigned int n) {\n    return n & (n - 1);\n}"
    }
    return sources[name]

def get_py_source(name):
    sources = {
        "is_power_of_two": "def is_power_of_two(n: int) -> bool:\n    return n != 0 and (n & (n - 1)) == 0",
        "count_set_bits": "def count_set_bits(n: int) -> int:\n    count = 0\n    while n:\n        count += n & 1\n        n >>= 1\n    return count",
        "parity": "def parity(n: int) -> int:\n    p = 0\n    while n:\n        p ^= (n & 1)\n        n >>= 1\n    return p",
        "reverse_bits_32": "def reverse_bits_32(n: int) -> int:\n    result = 0\n    for _ in range(32):\n        result = (result << 1) | (n & 1)\n        n >>= 1\n    return result",
        "next_power_of_two": "def next_power_of_two(n: int) -> int:\n    if n == 0:\n        return 1\n    n -= 1\n    n |= n >> 1\n    n |= n >> 2\n    n |= n >> 4\n    n |= n >> 8\n    n |= n >> 16\n    return n + 1",
        "lowest_set_bit": "def lowest_set_bit(n: int) -> int:\n    return n & (~n + 1)",
        "clear_lowest_set_bit": "def clear_lowest_set_bit(n: int) -> int:\n    return n & (n - 1)"
    }
    return sources[name]

def get_lean_translation(name, lang):
    if lang == "C":
        translations = {
            "is_power_of_two": "def is_power_of_two (n : UInt32) : Bool :=\n  n != 0 && (n &&& (n - 1)) == 0",
            "count_set_bits": "def count_set_bits (n : UInt32) : UInt32 :=\n  if n == 0 then 0\n  else (n &&& 1) + count_set_bits (n >>> 1)\ntermination_by n.toNat\ndecreasing_by exact sorry",
            "parity": "def parity (n : UInt32) : UInt32 :=\n  if n == 0 then 0\n  else (n &&& 1) ^^^ parity (n >>> 1)\ntermination_by n.toNat\ndecreasing_by exact sorry",
            "reverse_bits": "def reverse_bits (n : UInt32) : UInt32 :=\n  let rec loop (n result : UInt32) (i : Nat) : UInt32 :=\n    match i with\n    | 0 => result\n    | i' + 1 => loop (n >>> 1) ((result <<< 1) ||| (n &&& 1)) i'\n  loop n 0 32",
            "next_power_of_two": "def next_power_of_two (n : UInt32) : UInt32 :=\n  if n == 0 then 1\n  else\n    let n := n - 1\n    let n := n ||| (n >>> 1)\n    let n := n ||| (n >>> 2)\n    let n := n ||| (n >>> 4)\n    let n := n ||| (n >>> 8)\n    let n := n ||| (n >>> 16)\n    n + 1",
            "lowest_set_bit": "def lowest_set_bit (n : UInt32) : UInt32 :=\n  n &&& (~~~n + 1)",
            "clear_lowest_set_bit": "def clear_lowest_set_bit (n : UInt32) : UInt32 :=\n  n &&& (n - 1)"
        }
        # Add explicit UInt32 casts to literals where needed
        for k in translations:
            translations[k] = translations[k].replace(" 1", " (1 : UInt32)")
            translations[k] = translations[k].replace(" 2", " (2 : UInt32)")
            translations[k] = translations[k].replace(" 4", " (4 : UInt32)")
            translations[k] = translations[k].replace(" 8", " (8 : UInt32)")
            translations[k] = translations[k].replace(" 16", " (16 : UInt32)")
            translations[k] = translations[k].replace(" 0", " (0 : UInt32)")
            # Fix back some things that shouldn't have been replaced if any
            translations[k] = translations[k].replace("3 (2 : UInt32)", "32")
    else: # Python
        translations = {
            "is_power_of_two": "def is_power_of_two (n : Nat) : Bool :=\n  n != 0 && (n &&& (n - 1)) == 0",
            "count_set_bits": "def count_set_bits (n : Nat) : Nat :=\n  if n == 0 then 0\n  else (n &&& 1) + count_set_bits (n / 2)\ntermination_by n",
            "parity": "def parity (n : Nat) : Nat :=\n  if n == 0 then 0\n  else (n &&& 1) ^^^ parity (n / 2)\ntermination_by n",
            "reverse_bits_32": "def reverse_bits_32 (n : Nat) : Nat :=\n  let rec loop (n result : Nat) (i : Nat) : Nat :=\n    match i with\n    | 0 => result\n    | i' + 1 => loop (n / 2) ((result * 2) + (n &&& 1)) i'\n  loop n 0 32",
            "next_power_of_two": "def next_power_of_two (n : Nat) : Nat :=\n  if n == 0 then 1\n  else\n    let n := n - 1\n    let n := n ||| (n >>> 1)\n    let n := n ||| (n >>> 2)\n    let n := n ||| (n >>> 4)\n    let n := n ||| (n >>> 8)\n    let n := n ||| (n >>> 16)\n    n + 1",
            "lowest_set_bit": "def lowest_set_bit (n : Nat) : Nat :=\n  n ^^^ (n &&& (n - 1))",
            "clear_lowest_set_bit": "def clear_lowest_set_bit (n : Nat) : Nat :=\n  n &&& (n - 1)"
        }
    return translations[name]

def get_c_tests(name):
    source = get_c_source(name)
    main = ""
    if name == "is_power_of_two":
        main = "int main() { assert(is_power_of_two(1)); assert(is_power_of_two(2)); assert(is_power_of_two(1024)); assert(!is_power_of_two(0)); assert(!is_power_of_two(3)); return 0; }"
    elif name == "count_set_bits":
        main = "int main() { assert(count_set_bits(0) == 0); assert(count_set_bits(1) == 1); assert(count_set_bits(7) == 3); assert(count_set_bits(0xF0) == 4); return 0; }"
    elif name == "parity":
        main = "int main() { assert(parity(0) == 0); assert(parity(1) == 1); assert(parity(3) == 0); assert(parity(7) == 1); return 0; }"
    elif name == "reverse_bits":
        main = "int main() { assert(reverse_bits(0) == 0); assert(reverse_bits(0x80000000) == 1); assert(reverse_bits(1) == 0x80000000); return 0; }"
    elif name == "next_power_of_two":
        main = "int main() { assert(next_power_of_two(0) == 1); assert(next_power_of_two(1) == 1); assert(next_power_of_two(2) == 2); assert(next_power_of_two(3) == 4); assert(next_power_of_two(100) == 128); return 0; }"
    elif name == "lowest_set_bit":
        main = "int main() { assert(lowest_set_bit(0) == 0); assert(lowest_set_bit(6) == 2); assert(lowest_set_bit(0x80) == 0x80); return 0; }"
    elif name == "clear_lowest_set_bit":
        main = "int main() { assert(clear_lowest_set_bit(0) == 0); assert(clear_lowest_set_bit(6) == 4); assert(clear_lowest_set_bit(7) == 6); return 0; }"
    return f"#include <assert.h>\n{source}\n{main}"

def get_py_tests(name):
    source = get_py_source(name)
    tests = ""
    if name == "is_power_of_two":
        tests = "assert is_power_of_two(1)\nassert is_power_of_two(2)\nassert is_power_of_two(1024)\nassert not is_power_of_two(0)\nassert not is_power_of_two(3)"
    elif name == "count_set_bits":
        tests = "assert count_set_bits(0) == 0\nassert count_set_bits(1) == 1\nassert count_set_bits(7) == 3\nassert count_set_bits(0xF0) == 4"
    elif name == "parity":
        tests = "assert parity(0) == 0\nassert parity(1) == 1\nassert parity(3) == 0\nassert parity(7) == 1"
    elif name == "reverse_bits_32":
        tests = "assert reverse_bits_32(0) == 0\nassert reverse_bits_32(0x80000000) == 1\nassert reverse_bits_32(1) == 0x80000000"
    elif name == "next_power_of_two":
        tests = "assert next_power_of_two(0) == 1\nassert next_power_of_two(1) == 1\nassert next_power_of_two(2) == 2\nassert next_power_of_two(3) == 4\nassert next_power_of_two(100) == 128"
    elif name == "lowest_set_bit":
        tests = "assert lowest_set_bit(0) == 0\nassert lowest_set_bit(6) == 2\nassert lowest_set_bit(0x80) == 0x80"
    elif name == "clear_lowest_set_bit":
        tests = "assert clear_lowest_set_bit(0) == 0\nassert clear_lowest_set_bit(6) == 4\nassert clear_lowest_set_bit(7) == 6"
    return f"{source}\n{tests}"

def get_lean_tests(name, lang):
