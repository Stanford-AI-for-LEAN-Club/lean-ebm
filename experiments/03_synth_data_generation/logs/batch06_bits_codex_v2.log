+def theorem(name: str, statement: str, proof: str, proof_incomplete: bool) -> dict[str, object]:
+    return {
+        "name": name,
+        "statement": statement,
+        "proof": proof,
+        "proof_incomplete": proof_incomplete,
+    }
+
+
