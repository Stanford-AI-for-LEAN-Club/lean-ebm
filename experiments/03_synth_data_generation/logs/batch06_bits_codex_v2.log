+
+            def lowest_set_bit (n : Nat) : Nat :=
+              lowest_set_bit_go n 1 (n + 1)
+            """
+        ),
+        "clear_lowest_set_bit": block(
+            """
+            def clear_lowest_set_bit (n : Nat) : Nat :=
+              n - lowest_set_bit n
+            """
+        ),
+    }
+
