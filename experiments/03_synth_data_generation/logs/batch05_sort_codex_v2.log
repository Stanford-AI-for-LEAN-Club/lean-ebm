+
+            void swap(int *a, int *b) {
+                int tmp = *a;
+                *a = *b;
+                *b = tmp;
+            }
+
+            int partition(int *arr, int lo, int hi) {
+                int pivot = arr[hi];
+                int i = lo - 1;
+                for (int j = lo; j < hi; j++) {
+                    if (arr[j] <= pivot) {
+                        i++;
+                        swap(&arr[i], &arr[j]);
+                    }
+                }
+                swap(&arr[i + 1], &arr[hi]);
+                return i + 1;
+            }
+
+            static void assert_array_eq(const int *arr, const int *expected, int n) {
+                for (int i = 0; i < n; i++) {
