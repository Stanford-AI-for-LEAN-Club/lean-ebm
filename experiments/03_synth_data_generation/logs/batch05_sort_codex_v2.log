+            def is_sorted_ints : List Int → Prop
+              | [] => True
+              | [_] => True
+              | x :: y :: xs => x ≤ y ∧ is_sorted_ints (y :: xs)
+
+            def insert_sorted (x : Int) : List Int → List Int
+              | [] => [x]
+              | y :: ys =>
+                  if x ≤ y then
+                    x :: y :: ys
+                  else
