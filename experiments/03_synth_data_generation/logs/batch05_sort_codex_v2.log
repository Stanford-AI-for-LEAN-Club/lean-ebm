def get_lean_translation(name, lang):
    # Use Int for C/Python ints, but indices often better as Nat in Lean if we know they are >= 0.
    # For binary search, lo/hi can be Int because of hi = n - 1 (which can be -1).
    
    translations = {
        "linear_search": """partial def linear_search (arr : List Int) (target : Int) : Int :=
  let rec loop (i : Nat) : Int :=
    match arr.get? i with
    | some x => if x == target then i else loop (i + 1)
    | none => -1
  loop 0""",
        "binary_search": """partial def binary_search (arr : List Int) (target : Int) : Int :=
  let rec loop (lo hi : Int) : Int :=
    if lo > hi then -1
    else
      let mid := lo + (hi - lo) / 2
      match arr.get? mid.toNat with
      | some x =>
        if x == target then mid
        else if x < target then loop (mid + 1) hi
        else loop lo (mid - 1)
      | none => -1
  loop 0 (arr.length - 1)""",
        "find_first": """partial def find_first (arr : List Int) (target : Int) : Int :=
  let rec loop (lo hi result : Int) : Int :=
    if lo > hi then result
    else
      let mid := lo + (hi - lo) / 2
      match arr.get? mid.toNat with
      | some x =>
        if x == target then loop lo (mid - 1) mid
        else if x < target then loop (mid + 1) hi result
        else loop lo (mid - 1) result
      | none => result
  loop 0 (arr.length - 1) (-1)""",
        "find_last": """partial def find_last (arr : List Int) (target : Int) : Int :=
  let rec loop (lo hi result : Int) : Int :=
    if lo > hi then result
    else
      let mid := lo + (hi - lo) / 2
      match arr.get? mid.toNat with
      | some x =>
        if x == target then loop (mid + 1) hi mid
        else if x < target then loop (mid + 1) hi result
        else loop lo (mid - 1) result
      | none => result
  loop 0 (arr.length - 1) (-1)""",
        "contains": """def contains (arr : List Int) (val : Int) : Bool :=
  match arr with
  | [] => false
  | x :: xs => if x == val then true else contains xs val""" if lang == "Python" else
        """def contains (arr : List Int) (val : Int) : Int :=
