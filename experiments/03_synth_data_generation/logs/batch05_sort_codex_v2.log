+        "bubble_sort": block(
+            """
+            #include <assert.h>
+            #include <stdio.h>
+
+            void swap(int *a, int *b) {
+                int tmp = *a;
+                *a = *b;
+                *b = tmp;
+            }
+
+            void bubble_sort(int *arr, int n) {
+                for (int i = 0; i < n - 1; i++) {
+                    for (int j = 0; j < n - 1 - i; j++) {
