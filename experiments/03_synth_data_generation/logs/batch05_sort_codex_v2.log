+                *b = tmp;
+            }
+
+            int partition(int *arr, int lo, int hi) {
+                int pivot = arr[hi];
+                int i = lo - 1;
+                for (int j = lo; j < hi; j++) {
+                    if (arr[j] <= pivot) {
+                        i++;
+                        swap(&arr[i], &arr[j]);
