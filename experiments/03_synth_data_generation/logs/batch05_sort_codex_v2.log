+                *b = tmp;
+            }
+
+            int main() {
+                int x = 3;
+                int y = 7;
+                swap(&x, &y);
+                assert(x == 7);
+                assert(y == 3);
+
+                int a = -2;
+                int b = -2;
+                swap(&a, &b);
